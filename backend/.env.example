# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ecommerce

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
