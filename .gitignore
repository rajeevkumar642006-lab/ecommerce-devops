# ─────────────────────────────────────────────────────────────────────────────
# .gitignore  —  ecommerce-devops
# ─────────────────────────────────────────────────────────────────────────────

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.prod
*.env

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
backend/dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
combined.log
error.log

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep Dockerfiles and docker-compose.yml in git.
# Ignore local override files.
docker-compose.override.yml

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
.cache/
.parcel-cache/
